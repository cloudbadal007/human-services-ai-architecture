# Human Services AI Architecture — Environment Variables
# Copy this file to .env and adjust as needed

# Logging
LOG_LEVEL=INFO

# Compliance / EU AI Act
COMPLIANCE_ASSESSOR=Default Assessor

# Ontology paths (relative to project root)
ONTOLOGY_PATH=ontologies/

# Audit trail (in-memory for development; use database in production)
AUDIT_STORAGE=memory
